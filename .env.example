# Base URL of your external Better Auth / API server (no trailing slash).
# Copy this file to `.env` and adjust for your setup.
#
# Examples:
#   Web / iOS simulator:  http://localhost:3000
#   Android emulator:      http://10.0.2.2:3000
#   Physical device:       http://192.168.x.x:3000  (your machine's LAN IP)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Restart Metro after changing env vars: npx expo start --clear
#
# On your Better Auth *server* (not this app), add trusted origins:
#   trustedOrigins: [
#     "expoboilerplate://",
#     "exp://",
#     "exp://**",
#   ]
